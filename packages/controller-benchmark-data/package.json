{
  "name": "controller-benchmark-data",
  "version": "0.1.1",
  "description": "Versioned benchmark bundle and lightweight readers for the controller phase-stratified benchmark.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SproutSeeds/controller-benchmark-modules.git",
    "directory": "packages/controller-benchmark-data"
  },
  "homepage": "https://github.com/SproutSeeds/controller-benchmark-modules/tree/main/packages/controller-benchmark-data",
  "bugs": {
    "url": "https://github.com/SproutSeeds/controller-benchmark-modules/issues"
  },
  "type": "module",
  "main": "./src/index.js",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.js",
    "./bundle-manifest": "./data/phase-stratified-controller-benchmark-v0/bundle-manifest.json",
    "./data/*": "./data/*"
  },
  "files": [
    "src",
    "data",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bundle:refresh": "node ../../scripts/build-controller-benchmark-public-bundle.js",
    "prepublishOnly": "npm test && npm pack --dry-run",
    "test": "node --test",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm test && npm pack --dry-run"
  },
  "author": "SproutSeeds <cody@frg.earth>",
  "keywords": [
    "benchmark",
    "bundle",
    "condition-records",
    "controller",
    "data-package",
    "evidence",
    "provenance",
    "receipts",
    "research-data",
    "versioned-data"
  ]
}
